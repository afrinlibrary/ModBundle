<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#181818">

    <!-- App Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#242424"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:elevation="4dp"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_modbundle_logo"
            android:scaleType="centerCrop"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ModBundle"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"/>

    </LinearLayout>

    <!-- Content area fills remaining space -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- BROWSE TAB -->
        <LinearLayout
            android:id="@+id/layout_browse"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Source Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="4dp"
                android:background="#242424">
                <Button
                    android:id="@+id/btn_modrinth"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Modrinth"
                    android:textSize="13sp"
                    android:backgroundTint="#9649b8"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="4dp"
                    style="@style/Widget.MaterialComponents.Button"/>
                <Button
                    android:id="@+id/btn_curseforge"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="CurseForge"
                    android:textSize="13sp"
                    android:backgroundTint="#242424"
                    android:textColor="#AAAAAA"
                    android:layout_marginStart="4dp"
                    style="@style/Widget.MaterialComponents.Button"/>
            </LinearLayout>
            <!-- Content Type Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingBottom="4dp"
                android:background="#242424">
                <Button
                    android:id="@+id/btn_type_mods"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Mods"
                    android:textSize="11sp"
                    android:backgroundTint="#9649b8"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="3dp"
                    style="@style/Widget.MaterialComponents.Button"/>
                <Button
                    android:id="@+id/btn_type_resourcepack"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Res Packs"
                    android:textSize="11sp"
                    android:backgroundTint="#242424"
                    android:textColor="#AAAAAA"
                    android:layout_marginEnd="3dp"
                    style="@style/Widget.MaterialComponents.Button"/>
                <Button
                    android:id="@+id/btn_type_shader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Shaders"
                    android:textSize="11sp"
                    android:backgroundTint="#242424"
                    android:textColor="#AAAAAA"
                    style="@style/Widget.MaterialComponents.Button"/>
            </LinearLayout>
            <!-- Search Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:background="#242424">

                <EditText
                    android:id="@+id/search_input"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:hint="Search mods…"
                    android:textColorHint="#888888"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_search"
                    android:paddingHorizontal="14dp"
                    android:singleLine="true"
                    android:imeOptions="actionSearch"
                    android:inputType="text"/>
            </LinearLayout>

            <!-- Filters Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingBottom="8dp"
                android:background="#242424">

                <CheckBox
                    android:id="@+id/btn_snapshots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Include Snapshots"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp"
                    android:buttonTint="#9649b8"
                    android:checked="false"
                    android:layout_marginEnd="4dp"/>
                <Spinner
                    android:id="@+id/spinner_version"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_spinner"
                    android:popupBackground="#242424"
                    android:spinnerMode="dropdown"/>

                <Spinner
                    android:id="@+id/spinner_loader"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_spinner"
                    android:popupBackground="#242424"
                    android:spinnerMode="dropdown"/>
            </LinearLayout>

            <!-- Progress -->
            <ProgressBar
                android:id="@+id/browse_progress"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:indeterminate="true"
                android:indeterminateTint="#9649b8"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:visibility="gone"/>

            <!-- Mod List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/browse_recycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="8dp"/>

            <!-- Empty state -->
            <TextView
                android:id="@+id/empty_browse"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No mods found"
                android:textColor="#666"
                android:textSize="15sp"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone"/>

            <!-- Load More -->
            <Button
                android:id="@+id/btn_load_more"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Load More"
                android:textColor="#FFFFFF"
                android:backgroundTint="#9649b8"
                android:layout_margin="10dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- INSTALLED TAB -->
        <LinearLayout
            android:id="@+id/layout_installed"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:background="#242424">
                <TextView
                    android:id="@+id/installed_tab_mods"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Mods"
                    android:textColor="#9649b8"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"/>
                <TextView
                    android:id="@+id/installed_tab_shaders"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Shaders"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:gravity="center"/>
                <TextView
                    android:id="@+id/installed_tab_resourcepacks"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Res Packs"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:gravity="center"/>
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#9649b8"/>
            <!-- Toolbar row 1: file count + check updates -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="4dp">
                <TextView
                    android:id="@+id/tv_installed_count"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0 files"
                    android:textColor="#888888"
                    android:textSize="12sp"/>
                <Button
                    android:id="@+id/btn_check_updates"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="Check Updates"
                    android:textColor="#9649b8"
                    android:textSize="11sp"
                    android:backgroundTint="#242424"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>
            </LinearLayout>

            <!-- Toolbar row 2: select all + update selected (hidden until updates found) -->
            <LinearLayout
                android:id="@+id/layout_update_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:paddingBottom="6dp"
                android:visibility="gone">
                <CheckBox
                    android:id="@+id/cb_select_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select All"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:buttonTint="#9649b8"
                    android:layout_marginEnd="8dp"/>
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"/>
                <Button
                    android:id="@+id/btn_update_selected"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="Update Selected"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:backgroundTint="#242424"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:layout_marginEnd="6dp"/>
                <Button
                    android:id="@+id/btn_update_all"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="Update All"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:backgroundTint="#9649b8"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/installed_recycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="16dp"/>

            <TextView
                android:id="@+id/empty_installed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No mods installed yet"
                android:textColor="#666"
                android:textSize="15sp"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- SETTINGS TAB -->
        <LinearLayout
            android:id="@+id/layout_settings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:orientation="vertical">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"/>


            <!-- Auto Search Path Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Active Instance"
                android:textColor="#BBBBBB"
                android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <TextView
                android:id="@+id/tv_folder_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No instance selected"
                android:textColor="#888888"
                android:textSize="11sp"
                android:background="@drawable/bg_search"
                android:padding="12dp"
                android:layout_marginBottom="6dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select an instance from the Instances tab."
                android:textColor="#555555"
                android:textSize="11sp"
                android:layout_marginBottom="12dp"/>
            <Button
                android:id="@+id/btn_choose_folder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pick Instance Manually"
                android:textColor="#FFFFFF"
                android:backgroundTint="#9649b8"
                android:visibility="gone"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333"
                android:layout_marginVertical="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ModBundle"
                android:textColor="#555"
                android:textSize="11sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Part of the CopperLauncher project"
                android:textColor="#9649b8"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="4dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="github.com/CopperLauncher/ModBundle"
                android:textColor="#555"
                android:textSize="10sp"
                android:gravity="center"
                android:layout_marginTop="2dp"
                android:clickable="true"
                android:focusable="true"
                android:tag="https://github.com/CopperLauncher/ModBundle"
                android:id="@+id/tv_github_link"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="dsc.gg/CopperLauncher"
                android:textColor="#555"
                android:textSize="10sp"
                android:gravity="center"
                android:layout_marginTop="2dp"
                android:clickable="true"
                android:focusable="true"
                android:tag="https://dsc.gg/CopperLauncher"
                android:id="@+id/tv_discord_link"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Powered by Modrinth API &amp; CurseForge API"
                android:textColor="#444"
                android:textSize="10sp"
                android:gravity="center"
                android:layout_marginTop="6dp"/>

            </LinearLayout>
            </ScrollView>

        </LinearLayout>

    
        <include
            android:id="@+id/layout_instances"
            layout="@layout/layout_instances"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#242424"
        app:itemTextColor="#AAAAAA"
        app:itemIconTint="@drawable/bottom_nav_tint"
        app:menu="@menu/bottom_nav_menu"/>

</LinearLayout>
